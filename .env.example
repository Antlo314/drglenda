# UMOF Learning Portal — Supabase connection
# Copy this file to ".env" and paste your project's values.
# Find them in Supabase: Project Settings → API.
#
# Leaving these blank keeps the portal in local browser-demo mode.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Site chat assistant (Gemini) — used by the /api/chat serverless function.
# Set GEMINI_API_KEY in Vercel → Project → Settings → Environment Variables.
# Do NOT prefix with VITE_ — this key must stay server-side, never in the bundle.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-google-ai-studio-api-key
# Optional — override the model (defaults to gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash
