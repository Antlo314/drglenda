# UMOF Learning Portal — Supabase connection
# Copy this file to ".env" and paste your project's values.
# Find them in Supabase: Project Settings → API.
#
# Leaving these blank keeps the portal in local browser-demo mode.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
